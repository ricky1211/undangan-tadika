# Firebase Admin (dari Service Account JSON project Firebase kamu - sama dengan yang dipakai web)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Jam berapa (server time, 24h) cron reminder harian dijalankan, contoh "08:00"
REMINDER_CRON_HOUR=8
REMINDER_CRON_MINUTE=0

# Jeda antar pesan dikirim (detik), untuk mengurangi risiko diblokir WhatsApp
MIN_DELAY_SECONDS=4
MAX_DELAY_SECONDS=10

# Berapa pesan maksimal diproses per siklus antrian
BATCH_SIZE=15
